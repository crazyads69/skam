generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum CaseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SocialPlatform {
  FACEBOOK
  ZALO
  TELEGRAM
  X
  TIKTOK
  INSTAGRAM
}

model ScamCase {
  id                   String          @id @default(cuid())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  bankIdentifier       String
  bankName             String
  bankCode             String
  amount               Float?
  scammerName          String?
  originalDescription  String
  refinedDescription   String?
  status               CaseStatus      @default(PENDING)
  approvedAt           DateTime?
  approvedBy           String?
  rejectionReason      String?
  submitterFingerprint String?
  submitterIpHash      String?
  viewCount            Int             @default(0)
  profileId            String?
  profile              ScammerProfile? @relation(fields: [profileId], references: [id])
  evidenceFiles        EvidenceFile[]
  socialLinks          SocialLink[]

  @@index([bankIdentifier, bankCode])
  @@index([status])
  @@index([createdAt])
  @@index([profileId])
  @@index([submitterFingerprint])
  @@index([submitterIpHash])
}

model ScammerProfile {
  id              String       @id @default(cuid())
  bankIdentifier  String
  bankCode        String
  scammerName     String?
  totalCases      Int          @default(0)
  totalAmount     Float        @default(0)
  firstReportedAt DateTime
  lastReportedAt  DateTime
  cases           ScamCase[]
  socialLinks     SocialLink[]

  @@unique([bankIdentifier, bankCode])
}

model EvidenceFile {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  caseId     String
  case       ScamCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fileType   String
  fileKey    String
  fileName   String?
  fileSize   Int?
  fileHash   String?
  isApproved Boolean  @default(false)

  @@index([caseId])
  @@index([fileHash])
}

model SocialLink {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  platform  SocialPlatform
  url       String
  username  String?
  caseId    String?
  case      ScamCase?       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  profileId String?
  profile   ScammerProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([profileId])
}

model SystemStats {
  id                   String   @id @default("singleton")
  totalCases           Int      @default(0)
  totalApprovedCases   Int      @default(0)
  totalPendingCases    Int      @default(0)
  totalScammerProfiles Int      @default(0)
  totalScamAmount      Float    @default(0)
  updatedAt            DateTime @updatedAt
}
