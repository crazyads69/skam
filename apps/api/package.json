{
  "name": "@skam/api",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist --sourcemap",
    "start:prod": "bun dist/index.js",
    "lint": "echo \"api lint skipped\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src/**/*.test.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.887.0",
    "@aws-sdk/s3-request-presigner": "^3.887.0",
    "@elysiajs/cors": "^1.3.0",
    "@libsql/client": "^0.15.15",
    "@paralleldrive/cuid2": "^2.2.2",
    "@skam/shared": "workspace:*",
    "@upstash/redis": "^1.35.6",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.3.0",
    "jose": "^6.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.0",
    "supertest": "^7.1.4",
    "typescript": "^5.7.0"
  }
}
